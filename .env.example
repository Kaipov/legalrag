# Copy to .env and fill in your values.

# Evaluation API
EVAL_API_KEY=
EVAL_BASE_URL=https://platform.agentic-challenge.ai/api/v1

# Generation API keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Retrieval / embeddings API key
GEMINI_API_KEY=
VOYAGE_API_KEY=

# Optional API base overrides
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# EMBEDDING_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Optional retrieval/runtime overrides
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=models/gemini-embedding-2-preview
# EMBEDDING_BATCH_SIZE=16
# EMBEDDING_OUTPUT_DIMENSION=
# EMBEDDING_REQUEST_TIMEOUT_SECONDS=60
# EMBEDDING_MAX_RETRIES=5
# EMBEDDING_QUERY_TASK_TYPE=RETRIEVAL_QUERY
# EMBEDDING_DOCUMENT_TASK_TYPE=RETRIEVAL_DOCUMENT
# MAX_CHUNK_TOKENS=512
# MIN_CHUNK_TOKENS=100
# ENABLE_RERANKER=0
# RERANKER_PROVIDER=voyage
# RERANKER_ENABLED_INTENTS=article_ref
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_TOP_K=10
# RERANK_CANDIDATES=30
# RERANKER_TIMEOUT_SECONDS=10
# VOYAGE_API_BASE=https://api.voyageai.com/v1
# VOYAGE_RERANKER_MODEL=rerank-2.5
# RERANKER_BATCH_SIZE=4
# RERANKER_MAX_LENGTH=512
# RERANKER_USE_FP16=1
# GENERATION_MODEL=gpt-4.1-mini
# ENABLE_VISION_OCR_FALLBACK=1
# VISION_OCR_MODEL=gpt-4.1-mini
# VISION_OCR_MAX_OUTPUT_TOKENS=1500
# GPT-5.4 mini is a good trial replacement for gpt-4.1-mini in this pipeline:
# GENERATION_MODEL=gpt-5.4-mini
# GENERATION_TOP_K=4

# Optional output paths used by the starter kit
# SUBMISSION_PATH=submission.json
# CODE_ARCHIVE_PATH=code_archive.zip

# Optional documents directory override for starter-kit compatibility
# DOCS_DIR=docs_corpus
